        }

        const isOpen = row?.is_open === true
        const openTime = isOpen ? normalizeTimeValue(row?.open_time) : null
        const closeTime = isOpen ? normalizeTimeValue(row?.close_time) : null

        return {
          provider_id: providerId,
          day_of_week: day,
          is_open: isOpen,
          open_time: openTime,
          close_time: closeTime,
        }
